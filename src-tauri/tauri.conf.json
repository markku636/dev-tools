{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DB Kit",
  "version": "0.2.4",
  "identifier": "dev.dbkit.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "DB Kit",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.ico", "icons/icon.icns"],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
